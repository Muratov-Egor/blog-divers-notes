---
import BaseLayout from "../layouts/BaseLayout.astro";
import { t, localePath, type Locale } from "../lib/i18n";
import diveSites from "../../content/dive-sites.json";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const regions = diveSites as any[];
const sites = regions.flatMap((r) =>
  r.sites.map((s: any) => ({
    name: s.name,
    dives: s.dives,
    lat: s.coordinates?.lat,
    lng: s.coordinates?.lng,
    region: r.region?.[locale] ?? "",
    link: r.region?.links?.[0] ?? null,
  })),
).filter((s) => s.lat && s.lng);

const totalDives = sites.reduce((sum, s) => sum + (s.dives ?? 0), 0);
const countries = new Set(regions.map((r) => r.region?.country?.code)).size;
const stats = [
  [t(locale, "map.totalDives"), totalDives],
  [t(locale, "map.uniqueSites"), sites.length],
  [t(locale, "map.countriesVisited"), countries],
  [t(locale, "map.regionsVisited"), regions.length],
];
---

<BaseLayout
  locale={locale}
  title={`${t(locale, "map.title")} — Diver's Notes`}
  description={t(locale, "map.metaDescription")}
  path="/map"
>
  <h1 class="text-3xl font-semibold sm:text-4xl">{t(locale, "map.title")}</h1>

  <div class="mt-6 mb-8 flex flex-wrap gap-3">
    {stats.map(([label, value]) => (
      <div class="rounded-xl border border-line bg-surface px-4 py-2.5 font-mono text-sm">
        <b class="font-semibold text-lagoon">{value}</b>
        <span class="ml-1.5 text-muted">{label}</span>
      </div>
    ))}
  </div>

  <div
    id="dive-map"
    class="z-0 h-[28rem] w-full rounded-3xl shadow-card"
    data-sites={JSON.stringify(sites)}
    data-open-note={t(locale, "map.openNote")}
    data-locale-prefix={locale === "en" ? "/en" : ""}
  >
  </div>

  <section class="mt-12 max-w-4xl">
    <h2 class="mb-6 text-2xl font-semibold">{t(locale, "map.diveSitesList")}</h2>
    <div class="flex flex-col gap-3">
      {regions.map((r) => (
        <details class="rounded-2xl bg-surface p-5 shadow-card">
          <summary class="cursor-pointer font-display font-semibold">{r.region?.[locale]}</summary>
          <ul class="mt-3 grid gap-1.5 pl-1 text-[15px] sm:grid-cols-2">
            {r.sites.map((s: any) => (
              <li class="flex justify-between gap-3">
                <a href={s.googleMapsUrl} target="_blank" rel="noopener" class="hover:text-lagoon">
                  {s.name}
                </a>
                <span class="font-mono text-xs text-muted">{s.dives}</span>
              </li>
            ))}
          </ul>
          {r.region?.links?.[0] && (
            <a
              href={localePath(locale, r.region.links[0])}
              class="mt-3 inline-block text-sm text-lagoon hover:underline"
            >
              {t(locale, "map.openNote")} →
            </a>
          )}
        </details>
      ))}
    </div>
  </section>
</BaseLayout>

<script>
  import L from "leaflet";
  import "leaflet/dist/leaflet.css";

  const el = document.getElementById("dive-map")!;
  const sites = JSON.parse(el.dataset.sites!);
  const prefix = el.dataset.localePrefix ?? "";
  const openNote = el.dataset.openNote ?? "";

  const map = L.map(el).setView([15, 60], 3);
  L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
    attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
    maxZoom: 18,
  }).addTo(map);

  const bounds: [number, number][] = [];
  for (const s of sites) {
    bounds.push([s.lat, s.lng]);
    const link = s.link ? `<br><a href="${prefix}${s.link}">${openNote} →</a>` : "";
    L.circleMarker([s.lat, s.lng], {
      radius: 6,
      color: "#1F6E7B",
      fillColor: "#45C4D3",
      fillOpacity: 0.85,
    })
      .addTo(map)
      .bindPopup(`<b>${s.name}</b><br>${s.region}${link}`);
  }
  if (bounds.length) map.fitBounds(bounds, { padding: [30, 30] });
</script>
