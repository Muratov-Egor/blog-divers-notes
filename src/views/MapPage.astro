---
import BaseLayout from "../layouts/BaseLayout.astro";
import { t, localePath, diveCount, type Locale } from "../lib/i18n";
import { getBlogPosts } from "../lib/content";
import diveSites from "../../content/dive-sites.json";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const posts = await getBlogPosts(locale);
const titleBySlug = new Map(posts.map((p) => [`/blog/${p.data.slug}`, p.data.title]));
const noteLinks = (links: string[] | undefined) =>
  (links ?? []).map((link) => ({ link, title: titleBySlug.get(link) ?? t(locale, "map.openNote") }));

const regions = diveSites as any[];
const sites = regions.flatMap((r) =>
  r.sites.map((s: any) => ({
    name: s.name,
    dives: s.dives,
    lat: s.coordinates?.lat,
    lng: s.coordinates?.lng,
    region: r.region?.[locale] ?? "",
    links: noteLinks(r.region?.links),
  })),
).filter((s) => s.lat && s.lng);

const totalDives = sites.reduce((sum, s) => sum + (s.dives ?? 0), 0);
const countries = new Set(regions.map((r) => r.region?.country?.code)).size;
const chip = (key: string) => t(locale, key).replace(/:$/, "");
const stats = [
  [chip("map.totalDives"), totalDives],
  [chip("map.uniqueSites"), sites.length],
  [chip("map.countriesVisited"), countries],
  [chip("map.regionsVisited"), regions.length],
];
const typeLabel = (type: string | null | undefined) =>
  t(locale, `diveSiteTypes.${type && type !== "default" ? type : "default"}`);
---

<BaseLayout
  locale={locale}
  title={`${t(locale, "map.title")} — Diver's Notes`}
  description={t(locale, "map.metaDescription")}
  path="/map"
>
  <h1 class="text-3xl font-semibold sm:text-4xl">{t(locale, "map.title")}</h1>

  <div class="mt-6 mb-8 grid grid-cols-2 gap-3 sm:flex sm:flex-wrap">
    {stats.map(([label, value]) => (
      <div class="rounded-2xl bg-surface px-4 py-3 text-center shadow-card sm:flex sm:items-baseline sm:gap-2 sm:rounded-xl sm:border sm:border-line sm:px-4 sm:py-2.5 sm:text-left sm:shadow-none">
        <div class="text-xs text-muted sm:text-sm">{label}</div>
        <div class="mt-0.5 font-mono text-xl font-semibold text-lagoon sm:mt-0 sm:text-base">{value}</div>
      </div>
    ))}
  </div>

  <div
    id="dive-map"
    class="z-0 h-[28rem] w-full rounded-3xl shadow-card"
    data-sites={JSON.stringify(sites)}
    data-locale-prefix={locale === "en" ? "/en" : ""}
  >
  </div>

  <section class="mt-12">
    <h2 class="mb-6 text-2xl font-semibold">{t(locale, "map.diveSitesList")}</h2>
    <div class="flex flex-col gap-3">
      {regions.map((r) => (
        <details class="rounded-2xl bg-surface p-5 shadow-card sm:p-6">
          <summary class="cursor-pointer font-display text-lg font-semibold">
            {r.region?.[locale]}
          </summary>
          <ul class="mt-4 grid gap-x-10 gap-y-2 lg:grid-cols-2">
            {r.sites.map((s: any) => (
              <li class="flex items-baseline justify-between gap-4 border-b border-line py-1.5 text-[15px] last:border-b-0 lg:nth-last-2:border-b-0">
                <span class="min-w-0">
                  <a href={s.googleMapsUrl} target="_blank" rel="noopener" class="hover:text-lagoon">
                    {s.name}
                  </a>
                  <span class="ml-1.5 inline-block rounded-full bg-lagoon/10 px-2 py-0.5 align-middle text-[11px] whitespace-nowrap text-lagoon">
                    {typeLabel(s.type)}
                  </span>
                </span>
                <span class="shrink-0 font-mono text-xs whitespace-nowrap text-muted">
                  {s.dives} {diveCount(locale, s.dives)}
                </span>
              </li>
            ))}
          </ul>
          {noteLinks(r.region?.links).length > 0 && (
            <div class="mt-4 flex flex-wrap gap-x-6 gap-y-1">
              {noteLinks(r.region?.links).map(({ link, title }) => (
                <a href={localePath(locale, link)} class="text-sm text-lagoon hover:underline">
                  {title} →
                </a>
              ))}
            </div>
          )}
        </details>
      ))}
    </div>
  </section>
</BaseLayout>

<script>
  import maplibregl from "maplibre-gl";
  import "maplibre-gl/dist/maplibre-gl.css";

  const el = document.getElementById("dive-map")!;
  const sites = JSON.parse(el.dataset.sites!);
  const prefix = el.dataset.localePrefix ?? "";

  // Vector basemaps let us override label languages at render time.
  // Liberty is a colourful OSM-style basemap with rich place labels (incl. islands).
  const LIGHT_STYLE = "https://tiles.openfreemap.org/styles/liberty";
  const DARK_STYLE = "https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json";
  const isDark = () => document.documentElement.classList.contains("dark");

  const map = new maplibregl.Map({
    container: el,
    style: isDark() ? DARK_STYLE : LIGHT_STYLE,
    center: [60, 15],
    zoom: 2,
  });
  map.addControl(new maplibregl.NavigationControl({ showCompass: false }), "top-right");

  // Force every text label (cities, countries, oceans, …) to English.
  const englishLabels = () => {
    const nameEn = [
      "coalesce",
      ["get", "name:en"],
      ["get", "name_en"],
      ["get", "name_int"],
      ["get", "name:latin"],
      ["get", "name"],
    ];
    for (const layer of map.getStyle().layers ?? []) {
      if (layer.type === "symbol" && (layer.layout as any)?.["text-field"] !== undefined) {
        map.setLayoutProperty(layer.id, "text-field", nameEn as any);
      }
    }
  };

  // DOM markers + popups survive setStyle, so add them once.
  for (const s of sites) {
    const links = s.links
      .map((l: { link: string; title: string }) => `<a href="${prefix}${l.link}">${l.title} →</a>`)
      .join("<br>");
    const dot = document.createElement("div");
    dot.style.cssText =
      "width:14px;height:14px;border-radius:50%;background:#45C4D3;border:2px solid #1F6E7B;box-shadow:0 0 0 1px rgba(0,0,0,.15);cursor:pointer";
    new maplibregl.Marker({ element: dot })
      .setLngLat([s.lng, s.lat])
      .setPopup(
        new maplibregl.Popup({ offset: 12 }).setHTML(
          `<b>${s.name}</b><br>${s.region}${links ? "<br>" + links : ""}`,
        ),
      )
      .addTo(map);
  }

  const bounds = new maplibregl.LngLatBounds();
  for (const s of sites) bounds.extend([s.lng, s.lat]);
  if (!bounds.isEmpty()) map.fitBounds(bounds, { padding: 40, maxZoom: 8, animate: false });

  map.on("style.load", englishLabels);

  // Follow live theme toggles.
  new MutationObserver(() => {
    map.setStyle(isDark() ? DARK_STYLE : LIGHT_STYLE);
  }).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ["class"],
  });
</script>
