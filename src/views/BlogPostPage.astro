---
import { render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import CdnImage from "../components/CdnImage.astro";
import Lightbox from "../components/Lightbox.astro";
import PostCard from "../components/PostCard.astro";
import TagList from "../components/TagList.astro";
import { t, formatDate, type Locale } from "../lib/i18n";
import {
  getBlogPosts,
  postExistsInLocale,
  relatedPosts,
  readingTime,
  type BlogPost,
} from "../lib/content";
import { localePath } from "../lib/i18n";
import { resolveImage } from "../lib/images";

interface Props {
  locale: Locale;
  post: BlogPost;
}
const { locale, post } = Astro.props;
const { Content } = await render(post);
const all = await getBlogPosts(locale);
const related = relatedPosts(post, all);
const ogImage = post.data.cover ? resolveImage(post.data.cover).src : undefined;
const minutes = readingTime(post.body);
const site = Astro.site!.href.replace(/\/$/, "");
const postUrl = site + localePath(locale, `/blog/${post.data.slug}`);
// Only claim a cross-locale alternate if the translation actually exists.
const hasAlternate = await postExistsInLocale(post.data.slug, locale === "ru" ? "en" : "ru");

const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  url: postUrl,
  inLanguage: locale,
  datePublished: post.data.date.toISOString(),
  dateModified: (post.data.updatedAt ?? post.data.date).toISOString(),
  ...(ogImage ? { image: ogImage } : {}),
  mainEntityOfPage: { "@type": "WebPage", "@id": postUrl },
  author: { "@type": "Organization", name: "Diver's Notes" },
  publisher: { "@type": "Organization", name: "Diver's Notes" },
};
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: t(locale, "nav.blog"), item: site + localePath(locale, "/blog") },
    { "@type": "ListItem", position: 2, name: post.data.title, item: postUrl },
  ],
};
// Article "depth": ~5 m per minute of reading, in sane diving bounds (10–60 m).
const maxDepth = Math.min(60, Math.max(10, minutes * 5));
---

<BaseLayout
  locale={locale}
  title={`${post.data.title} — Diver's Notes`}
  description={post.data.description}
  path={`/blog/${post.data.slug}`}
  ogImage={ogImage}
  ogType="article"
  hasAlternate={hasAlternate}
  jsonLd={[blogPostingSchema, breadcrumbSchema]}
>
  <div class="relative mx-auto max-w-[60rem]">
    <!-- Depth scale: reading progress rendered as a dive from 0 m.
         Sticky viewport-height gauge so it stays visible on long articles. -->
    <div
      class="absolute top-0 bottom-0 -left-24 hidden w-10 font-mono text-[11px] text-muted xl:block"
      aria-hidden="true"
    >
      <div class="sticky top-28 h-[70vh]" id="depth-gauge" data-max-depth={maxDepth}>
        <div class="absolute top-0 bottom-0 left-1/2 w-0.5 bg-line"></div>
        <div id="depth-fill" class="absolute top-0 left-1/2 w-0.5 bg-lagoon" style="height:0%"></div>
        <span class="absolute top-0">0м</span>
        <span id="depth-label" class="absolute text-lagoon" style="top:0%">−0</span>
        <span class="absolute bottom-0">−{maxDepth}</span>
      </div>
    </div>

    <article data-pagefind-body data-pagefind-filter="type:blog">
      <header class="mb-8">
        <h1 class="text-3xl leading-tight font-semibold sm:text-[2.6rem]">{post.data.title}</h1>
        <p class="mt-3 font-mono text-[13px] text-muted">
          <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date, locale)}</time>
          {" · "}
          {t(locale, "blog.readingTime").replace("{minutes}", String(minutes))}
        </p>
        {post.data.cover && (
          <CdnImage
            src={post.data.cover}
            alt={post.data.title}
            loading="eager"
            class="mt-6 w-full rounded-3xl shadow-card"
          />
        )}
      </header>
      <div class="prose max-w-none">
        <Content />
      </div>
      <TagList tags={post.data.tags} locale={locale} class="mt-10" />
    </article>
  </div>

  {related.length > 0 && (
    <section class="mx-auto mt-16 max-w-5xl">
      <h2 class="mb-6 text-2xl font-semibold">
        {locale === "ru" ? "Похожие статьи" : "Related posts"}
      </h2>
      <div class="grid gap-7 sm:grid-cols-2 lg:grid-cols-3">
        {related.map((p) => <PostCard post={p} locale={locale} />)}
      </div>
    </section>
  )}
  <Lightbox />
</BaseLayout>

<script>
  const fill = document.getElementById("depth-fill");
  const label = document.getElementById("depth-label");
  const article = document.querySelector("article");
  const maxDepth = Number(document.getElementById("depth-gauge")?.dataset.maxDepth ?? 30);
  if (fill && label && article) {
    const update = () => {
      // Progress through the article itself, not the whole page.
      const start = article.getBoundingClientRect().top + scrollY;
      const end = start + (article as HTMLElement).offsetHeight - innerHeight;
      const p = end > start ? Math.min(1, Math.max(0, (scrollY - start) / (end - start))) : 1;
      fill.style.height = `${p * 100}%`;
      label.style.top = `${p * 100}%`;
      label.textContent = `−${Math.round(p * maxDepth)}`;
    };
    addEventListener("scroll", update, { passive: true });
    addEventListener("resize", update, { passive: true });
    update();
  }
</script>
