---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import CdnImage from "../components/CdnImage.astro";
import { t, localePath, type Locale } from "../lib/i18n";
import { getBlogPosts, getMarineLife, type TagMeta } from "../lib/content";

interface Props {
  locale: Locale;
  tag: TagMeta;
}
const { locale, tag } = Astro.props;
const names = [tag.ru, tag.en];
const posts = (await getBlogPosts(locale)).filter((p) =>
  p.data.tags.some((x) => names.includes(x)),
);
const marine = (await getMarineLife(locale)).filter((m) =>
  m.data.tags.some((x) => names.includes(x)),
);
const title = t(locale, "tags.tagTitle").replace("{name}", tag[locale]);
---

<BaseLayout
  locale={locale}
  title={`${title} — Diver's Notes`}
  description={t(locale, "tags.tagDescription").replace("{name}", tag[locale])}
  path={`/tags/${tag.slug}`}
>
  <h1 class="text-3xl font-semibold sm:text-4xl">{title}</h1>
  <p class="mt-3 mb-10 font-mono text-sm text-muted">
    {t(locale, "tags.foundMaterials").replace("{count}", String(posts.length + marine.length))}
  </p>

  {posts.length === 0 && marine.length === 0 && (
    <p class="text-muted">{t(locale, "tags.noMaterialsWithTag")}</p>
  )}

  {posts.length > 0 && (
    <section class="mb-12">
      <h2 class="mb-6 text-2xl font-semibold">{t(locale, "nav.blog")}</h2>
      <div class="grid gap-7 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => <PostCard post={post} locale={locale} />)}
      </div>
    </section>
  )}

  {marine.length > 0 && (
    <section>
      <h2 class="mb-6 text-2xl font-semibold">{t(locale, "nav.marineLife")}</h2>
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-3 lg:grid-cols-4">
        {marine.map((m) => (
          <a
            href={localePath(locale, `/marine-life/${m.data.slug}`)}
            class="group overflow-hidden rounded-3xl bg-surface shadow-card transition-transform duration-300 motion-safe:hover:-translate-y-1"
          >
            {m.data.images[0] && (
              <CdnImage
                src={m.data.images[0]}
                alt={m.data.title}
                sizes="(max-width: 640px) 50vw, 300px"
                class="aspect-square w-full object-cover"
              />
            )}
            <div class="p-4">
              <h3 class="font-display text-[15px] leading-snug font-semibold group-hover:text-lagoon">
                {m.data.title}
              </h3>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
