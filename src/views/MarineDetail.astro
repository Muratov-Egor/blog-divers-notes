---
import { render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import CdnImage from "../components/CdnImage.astro";
import Lightbox from "../components/Lightbox.astro";
import TagList from "../components/TagList.astro";
import { t, localePath, type Locale } from "../lib/i18n";
import type { MarineEntry } from "../lib/content";
import { resolveImage } from "../lib/images";

interface Props {
  locale: Locale;
  entry: MarineEntry;
}
const { locale, entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const ogImage = d.images[0] ? resolveImage(d.images[0]).src : undefined;

const site = Astro.site!.href.replace(/\/$/, "");
const entryUrl = site + localePath(locale, `/marine-life/${d.slug}`);

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: d.title,
  description: d.description,
  url: entryUrl,
  inLanguage: locale,
  ...(ogImage ? { image: ogImage } : {}),
  mainEntityOfPage: { "@type": "WebPage", "@id": entryUrl },
  author: { "@type": "Organization", name: "Diver's Notes" },
  publisher: { "@type": "Organization", name: "Diver's Notes" },
  ...(d.latinName ? { about: { "@type": "Thing", name: d.latinName } } : {}),
};
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: t(locale, "nav.marineLife"),
      item: site + localePath(locale, "/marine-life"),
    },
    { "@type": "ListItem", position: 2, name: d.title, item: entryUrl },
  ],
};

const facts: [string, string | undefined][] = [
  [t(locale, "marineLifeInfo.size"), d.size],
  [t(locale, "marineLifeInfo.depth"), d.depthRange],
  [t(locale, "marineLifeInfo.family"), d.family],
  [t(locale, "marineLifeInfo.type"), d.category],
  [t(locale, "marineLifeInfo.activity"), d.activity],
  [t(locale, "marineLifeInfo.habitat"), d.locations.join("; ") || undefined],
  [t(locale, "marineLifeInfo.conservationStatus"), d.conservationStatus],
];
---

<BaseLayout
  locale={locale}
  title={`${d.title} — Diver's Notes`}
  description={d.description}
  path={`/marine-life/${d.slug}`}
  ogImage={ogImage}
  ogType="article"
  jsonLd={[articleSchema, breadcrumbSchema]}
>
  <div class="mx-auto max-w-[60rem]">
    <article data-pagefind-body data-pagefind-filter="type:marine">
      <h1 class="text-3xl leading-tight font-semibold sm:text-[2.6rem]">{d.title}</h1>
      <p class="mt-2 mb-6 font-mono text-[13px] text-muted">
        {[d.nameEn, d.latinName].filter(Boolean).join(" · ")}
      </p>

      {d.images[0] && (
        <CdnImage src={d.images[0]} alt={d.title} loading="eager" class="mb-8 w-full rounded-3xl shadow-card" />
      )}

      <section class="mb-8 rounded-3xl bg-surface p-6 shadow-card sm:p-7">
        <h2 class="mb-4 text-lg font-semibold">{t(locale, "marineLifeInfo.briefInfo")}</h2>
        <dl class="grid gap-x-8 gap-y-3 text-[15px] sm:grid-cols-2">
          {facts
            .filter(([, v]) => v)
            .map(([label, value]) => (
              <div>
                <dt class="font-mono text-xs tracking-wide text-lagoon uppercase">{label}</dt>
                <dd class="mt-0.5">{value}</dd>
              </div>
            ))}
        </dl>
      </section>

      <div class="prose max-w-none">
        <Content />
      </div>

      <TagList tags={d.tags} locale={locale} class="mt-8" />
    </article>
  </div>
  <Lightbox />
</BaseLayout>
