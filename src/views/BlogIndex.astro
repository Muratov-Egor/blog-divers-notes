---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { t, type Locale } from "../lib/i18n";
import { getBlogPosts } from "../lib/content";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const posts = await getBlogPosts(locale);
const [newest, ...rest] = posts;
---

<BaseLayout
  locale={locale}
  title={`${t(locale, "blog.title")} — Diver's Notes`}
  description={t(locale, "blog.metaDescription")}
  path="/blog"
>
  <h1 class="text-3xl font-semibold sm:text-4xl">{t(locale, "blog.title")}</h1>
  <p class="mt-3 mb-10 max-w-2xl text-muted">{t(locale, "blog.subtitle")}</p>
  {newest && <PostCard post={newest} locale={locale} featured />}
  <div class="mt-7 grid gap-7 sm:grid-cols-2 lg:grid-cols-3">
    {rest.map((post) => <PostCard post={post} locale={locale} />)}
  </div>
</BaseLayout>
