---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import Pagination from "../components/Pagination.astro";
import { t, type Locale } from "../lib/i18n";
import { getBlogPosts, blogTotalPages, blogPageSlice } from "../lib/content";

interface Props {
  locale: Locale;
  page?: number;
}
const { locale, page = 1 } = Astro.props;
const all = await getBlogPosts(locale);
const totalPages = blogTotalPages(all.length);
const pagePosts = blogPageSlice(all, page);
const [featured, ...rest] = page === 1 ? pagePosts : [undefined, ...pagePosts];
const path = page === 1 ? "/blog" : `/blog/page/${page}`;
const pageSuffix =
  page > 1
    ? ` — ${t(locale, "pagination.pageOfTotal").replace("{current}", String(page)).replace("{total}", String(totalPages))}`
    : "";
---

<BaseLayout
  locale={locale}
  title={`${t(locale, "blog.title")}${pageSuffix} — Diver's Notes`}
  description={t(locale, "blog.metaDescription")}
  path={path}
>
  <h1 class="text-3xl font-semibold sm:text-4xl">{t(locale, "blog.title")}</h1>
  <p class="mt-3 mb-10 max-w-2xl text-muted">{t(locale, "blog.subtitle")}</p>
  {featured && <PostCard post={featured} locale={locale} featured />}
  <div class="mt-7 grid gap-7 sm:grid-cols-2 lg:grid-cols-3">
    {rest.filter(Boolean).map((post) => <PostCard post={post!} locale={locale} />)}
  </div>
  <Pagination locale={locale} current={page} total={totalPages} basePath="/blog" />
</BaseLayout>
