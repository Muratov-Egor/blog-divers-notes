---
import BaseLayout from "../layouts/BaseLayout.astro";
import { t, localePath, type Locale } from "../lib/i18n";
import { allTags, getBlogPosts, getMarineLife } from "../lib/content";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const posts = await getBlogPosts(locale);
const marine = await getMarineLife(locale);

const counts = allTags
  .map((tag) => {
    const names = [tag.ru, tag.en];
    const count =
      posts.filter((p) => p.data.tags.some((x) => names.includes(x))).length +
      marine.filter((m) => m.data.tags.some((x) => names.includes(x))).length;
    return { tag, count };
  })
  .filter((x) => x.count > 0)
  .sort((a, b) => b.count - a.count);
---

<BaseLayout
  locale={locale}
  title={`${t(locale, "tags.title")} — Diver's Notes`}
  description={t(locale, "tags.metaDescription")}
  path="/tags"
>
  <h1 class="text-3xl font-semibold sm:text-4xl">{t(locale, "tags.title")}</h1>
  <p class="mt-3 mb-10 max-w-2xl text-muted">{t(locale, "tags.subtitle")}</p>
  <ul class="flex max-w-4xl flex-wrap gap-3">
    {counts.map(({ tag, count }) => (
      <li>
        <a
          href={localePath(locale, `/tags/${tag.slug}`)}
          class="inline-flex items-center gap-2 rounded-full bg-lagoon/10 px-4 py-2 text-sm text-lagoon transition-colors hover:bg-lagoon/20"
        >
          {tag[locale]}
          <span class="font-mono text-xs opacity-70">{count}</span>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>
