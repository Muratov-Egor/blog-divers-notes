---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { t, localePath, type Locale } from "../lib/i18n";
import { getBlogPosts } from "../lib/content";
import diveSites from "../../content/dive-sites.json";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const posts = await getBlogPosts(locale);
const latest = posts.slice(0, 6);

const regions = diveSites as any[];
const sites = regions.flatMap((r) => r.sites);
const stats = [
  [t(locale, "home.totalDives"), sites.reduce((s, x) => s + (x.dives ?? 0), 0)],
  [t(locale, "home.diveSites"), sites.length],
  [t(locale, "home.countries"), new Set(regions.map((r) => r.region?.country?.code)).size],
  [t(locale, "home.regions"), regions.length],
];
---

<BaseLayout
  locale={locale}
  title={t(locale, "home.title")}
  description={t(locale, "home.metaDescription")}
  path="/"
>
  <section class="flex flex-col-reverse items-center gap-10 py-8 lg:flex-row lg:gap-16">
    <div class="flex-1">
      <h1 class="text-4xl leading-tight font-semibold sm:text-5xl">Diver's Notes</h1>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed">{t(locale, "home.intro1")}</p>
      <p class="mt-3 max-w-2xl leading-relaxed text-muted">{t(locale, "home.intro2")}</p>
      <div class="mt-8 flex flex-wrap gap-3">
        {stats.map(([label, value]) => (
          <div class="rounded-xl border border-line bg-surface px-4 py-2.5 font-mono text-sm">
            <b class="font-semibold text-lagoon">{value}</b>
            <span class="ml-1.5 text-muted">{label}</span>
          </div>
        ))}
      </div>
    </div>
    <img
      src="/mainPage/hero.png"
      alt={t(locale, "home.heroAlt")}
      class="w-full max-w-xs rounded-3xl shadow-card lg:max-w-sm"
      width="768"
      height="768"
      loading="eager"
    />
  </section>

  <section class="mt-12">
    <div class="mb-6 flex items-baseline justify-between">
      <h2 class="text-2xl font-semibold">{t(locale, "home.latestPosts")}</h2>
      <a href={localePath(locale, "/blog")} class="text-sm text-lagoon hover:underline">
        {t(locale, "nav.blog")} →
      </a>
    </div>
    <div class="grid gap-7 sm:grid-cols-2 lg:grid-cols-3">
      {latest.map((post) => <PostCard post={post} locale={locale} />)}
    </div>
  </section>
</BaseLayout>
