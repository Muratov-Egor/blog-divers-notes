---
import BaseLayout from "../layouts/BaseLayout.astro";
import CdnImage from "../components/CdnImage.astro";
import { t, localePath, type Locale } from "../lib/i18n";
import { getMarineLife } from "../lib/content";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const entries = await getMarineLife(locale);
---

<BaseLayout
  locale={locale}
  title={`${t(locale, "marineLife.title")} — Diver's Notes`}
  description={t(locale, "marineLife.metaDescription")}
  path="/marine-life"
>
  <h1 class="max-w-3xl text-3xl leading-tight font-semibold sm:text-4xl">
    {t(locale, "marineLife.title")}
  </h1>
  <p class="mt-3 mb-10 max-w-2xl text-muted">{t(locale, "marineLife.subtitle")}</p>
  <div class="grid grid-cols-2 gap-6 sm:grid-cols-3 lg:grid-cols-4">
    {entries.map((entry) => (
      <a
        href={localePath(locale, `/marine-life/${entry.data.slug}`)}
        class="group overflow-hidden rounded-3xl bg-surface shadow-card transition-transform duration-300 motion-safe:hover:-translate-y-1"
      >
        {entry.data.images[0] && (
          <div class="overflow-hidden">
            <CdnImage
              src={entry.data.images[0]}
              alt={entry.data.title}
              sizes="(max-width: 640px) 50vw, 300px"
              class="aspect-square w-full object-cover transition-transform duration-500 motion-safe:group-hover:scale-[1.04]"
            />
          </div>
        )}
        <div class="p-4">
          <h2 class="font-display text-[15px] leading-snug font-semibold group-hover:text-lagoon">
            {entry.data.title}
          </h2>
          {entry.data.latinName && (
            <p class="mt-0.5 text-xs text-muted italic">{entry.data.latinName}</p>
          )}
        </div>
      </a>
    ))}
  </div>
</BaseLayout>
