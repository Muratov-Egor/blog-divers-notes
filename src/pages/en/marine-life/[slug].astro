---
import MarineDetail from "@/views/MarineDetail.astro";
import { getMarineLife } from "@/lib/content";

export async function getStaticPaths() {
  const entries = await getMarineLife("en");
  return entries.map((entry) => ({ params: { slug: entry.data.slug }, props: { entry } }));
}

const { entry } = Astro.props;
---

<MarineDetail locale="en" entry={entry} />
