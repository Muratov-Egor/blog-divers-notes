---
import MarineIndex from "@/views/MarineIndex.astro";
import { getMarineLife, MARINE_PER_PAGE } from "@/lib/content";

export async function getStaticPaths() {
  const total = Math.max(1, Math.ceil((await getMarineLife("ru")).length / MARINE_PER_PAGE));
  return Array.from({ length: total - 1 }, (_, i) => ({ params: { page: String(i + 2) } }));
}

const page = Number(Astro.params.page);
---

<MarineIndex locale="ru" page={page} />
