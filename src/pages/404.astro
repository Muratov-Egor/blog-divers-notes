---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { t } from "@/lib/i18n";
---

<BaseLayout locale="ru" title="404 — Diver's Notes" path="/404">
  <div class="py-20 text-center">
    <p class="font-mono text-sm text-muted">{t("ru", "notFound.hint")}</p>
    <p class="mt-4 font-display text-7xl font-semibold text-lagoon">404</p>
    <h1 class="mt-4 text-2xl font-semibold">{t("ru", "notFound.title")}</h1>
    <p class="mt-2 text-muted">{t("ru", "notFound.description")}</p>
    <a
      href="/"
      class="mt-8 inline-block rounded-xl bg-action px-6 py-3 font-semibold text-white transition-opacity hover:opacity-90 dark:text-[#06171F]"
    >
      {t("ru", "notFound.goHome")}
    </a>
  </div>
</BaseLayout>
