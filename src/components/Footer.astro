  },
  {
    href: "https://www.youtube.com/@diversnotes",
    label: "YouTube",
    icon: "M23 7.3s-.2-1.6-.9-2.3c-.9-.9-1.9-.9-2.3-1C16.6 3.7 12 3.7 12 3.7s-4.6 0-7.8.3c-.4.1-1.4.1-2.3 1-.7.7-.9 2.3-.9 2.3S.8 9.2.8 11v1.9c0 1.9.2 3.8.2 3.8s.2 1.6.9 2.3c.9.9 2 .9 2.5 1 1.8.2 7.6.3 7.6.3s4.6 0 7.8-.3c.4-.1 1.4-.1 2.3-1 .7-.7.9-2.3.9-2.3s.2-1.9.2-3.8V11c0-1.8-.2-3.7-.2-3.7ZM9.7 15.1V8.4l6.2 3.4-6.2 3.3Z",
  },
  {
    href: "https://t.me/diversnotes",
    label: "Telegram",
    icon: "M21.9 4.4 18.6 19.7c-.2 1.1-.9 1.4-1.8.9l-4.9-3.6-2.4 2.3c-.3.3-.5.5-1 .5l.4-5 9.2-8.3c.4-.4-.1-.6-.6-.2l-11.4 7.2-4.9-1.5c-1.1-.3-1.1-1.1.2-1.6L20.5 2.7c.9-.3 1.7.2 1.4 1.7Z",
  },
  {
    href: "mailto:egor_muratov@hotmail.com",
    label: "Email",
    icon: "M2 5.5A1.5 1.5 0 0 1 3.5 4h17A1.5 1.5 0 0 1 22 5.5v13a1.5 1.5 0 0 1-1.5 1.5h-17A1.5 1.5 0 0 1 2 18.5v-13Zm2.2.5 7.8 6.2L19.8 6H4.2ZM20 8.1l-7.4 5.9a1 1 0 0 1-1.2 0L4 8.1V18h16V8.1Z",
