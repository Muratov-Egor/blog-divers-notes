---

<footer class="border-t border-line py-10 text-sm text-muted">
  <div class="mx-auto flex max-w-7xl flex-col gap-6 px-6 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="font-display font-semibold text-ink">Diver's Notes</p>
      <p class="mt-1 max-w-md">{t(locale, "footer.description")}</p>
    </div>
    <div class="flex flex-col gap-3 sm:items-end">
      <div class="flex items-center gap-2">
        {socials.map((s) => (
          <a
            href={s.href}
            aria-label={s.label}
            target={s.href.startsWith("http") ? "_blank" : undefined}
            rel={s.href.startsWith("http") ? "noopener" : undefined}
            class="flex h-10 w-10 items-center justify-center rounded-full border border-line bg-surface text-muted transition-colors hover:text-lagoon"
          >
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true">
              <path d={s.icon}></path>
            </svg>
          </a>
        ))}
      </div>
      <div class="flex items-center gap-5">
        <a href={localePath(locale, "/rss.xml")} class="text-lagoon hover:underline">
          {t(locale, "footer.rss")}
        </a>
        <span class="font-mono text-xs">{t(locale, "footer.copyright")}</span>
      </div>
    </div>
  </div>
</footer>
