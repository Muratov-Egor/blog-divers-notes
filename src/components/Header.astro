---
import { t, localePath, alternatePath, type Locale } from "../lib/i18n";
import Search from "./Search.astro";

interface Props {
  locale: Locale;
  path: string;
}
const { locale, path } = Astro.props;

const nav = [
  { href: "/blog", label: t(locale, "nav.blog") },
  { href: "/marine-life", label: t(locale, "nav.marineLife") },
  { href: "/map", label: t(locale, "nav.map") },
];
const isActive = (href: string) => path === href || path.startsWith(href + "/");
const iconBtn =
  "flex h-10 w-10 items-center justify-center rounded-full border border-line bg-surface text-muted transition-colors hover:text-lagoon";
---

<header class="sticky top-0 z-40 border-b border-line bg-ground/90 backdrop-blur">
  <div class="mx-auto flex max-w-7xl items-center gap-3 px-4 py-3 sm:px-6 sm:py-4 md:gap-6">
    <a href={localePath(locale, "/")} class="flex min-w-0 items-center gap-2.5">
      <img
        src="/logo.png"
        alt={t(locale, "metadata.logoAlt")}
        class="h-9 w-9 shrink-0 rounded-full"
        width="36"
        height="36"
      />
      <span class="truncate font-display text-lg font-semibold">Diver's Notes</span>
    </a>

    <nav class="hidden flex-1 items-center gap-6 text-[15px] md:flex">
      {nav.map((item) => (
        <a
          href={localePath(locale, item.href)}
          class:list={[
            "pb-0.5 transition-colors",
            isActive(item.href)
              ? "border-b-2 border-action font-medium text-ink"
              : "text-muted hover:text-ink",
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="ml-auto flex items-center gap-2">
      <Search locale={locale} />
      <button
        id="theme-toggle"
        aria-label={t(locale, "theme.toggle")}
        class:list={[iconBtn, "hidden md:flex"]}
      >
        <svg viewBox="0 0 24 24" class="h-5 w-5 dark:hidden" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"></path>
        </svg>
        <svg viewBox="0 0 24 24" class="hidden h-5 w-5 dark:block" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2m0 16v2M4.9 4.9l1.4 1.4m11.4 11.4 1.4 1.4M2 12h2m16 0h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path>
        </svg>
      </button>
      <a
        href={alternatePath(locale, path)}
        class:list={[iconBtn, "hidden font-mono text-xs font-semibold md:flex"]}
      >
        {locale === "ru" ? "EN" : "RU"}
      </a>
      <button
        id="menu-toggle"
        aria-label="Menu"
        aria-expanded="false"
        class:list={[iconBtn, "md:hidden"]}
      >
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path class="menu-open" d="M4 7h16M4 12h16M4 17h16"></path>
          <path class="menu-close hidden" d="M6 6l12 12M18 6L6 18"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-line px-4 pt-2 pb-4 md:hidden">
    <nav class="flex flex-col">
      {nav.map((item) => (
        <a
          href={localePath(locale, item.href)}
          class:list={[
            "rounded-xl px-3 py-2.5 text-[15px] transition-colors",
            isActive(item.href) ? "bg-lagoon/10 font-medium text-lagoon" : "text-ink hover:bg-surface",
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>
    <div class="mt-3 flex items-center gap-2 border-t border-line pt-3">
      <button id="theme-toggle-mobile" aria-label={t(locale, "theme.toggle")} class={iconBtn}>
        <svg viewBox="0 0 24 24" class="h-5 w-5 dark:hidden" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"></path>
        </svg>
        <svg viewBox="0 0 24 24" class="hidden h-5 w-5 dark:block" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2m0 16v2M4.9 4.9l1.4 1.4m11.4 11.4 1.4 1.4M2 12h2m16 0h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path>
        </svg>
      </button>
      <a
        href={alternatePath(locale, path)}
        class:list={[iconBtn, "font-mono text-xs font-semibold"]}
      >
        {locale === "ru" ? "EN" : "RU"}
      </a>
    </div>
  </div>
</header>

<script>
  const toggleTheme = () => {
    const dark = document.documentElement.classList.toggle("dark");
    localStorage.setItem("theme", dark ? "dark" : "light");
  };
  document.getElementById("theme-toggle")?.addEventListener("click", toggleTheme);
  document.getElementById("theme-toggle-mobile")?.addEventListener("click", toggleTheme);

  const menuBtn = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  menuBtn?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false;
    menuBtn.setAttribute("aria-expanded", String(open));
    menuBtn.querySelector(".menu-open")?.classList.toggle("hidden", open);
    menuBtn.querySelector(".menu-close")?.classList.toggle("hidden", !open);
  });
</script>
