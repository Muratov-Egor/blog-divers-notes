---
import { t, localePath, alternatePath, type Locale } from "../lib/i18n";
import Search from "./Search.astro";

interface Props {
  locale: Locale;
  path: string;
}
const { locale, path } = Astro.props;

const nav = [
  { href: "/blog", label: t(locale, "nav.blog") },
  { href: "/marine-life", label: t(locale, "nav.marineLife") },
  { href: "/map", label: t(locale, "nav.map") },
];
const isActive = (href: string) => path === href || path.startsWith(href + "/");
---

<header class="sticky top-0 z-40 border-b border-line bg-ground/90 backdrop-blur">
  <div class="mx-auto flex max-w-7xl items-center gap-6 px-6 py-4">
    <a href={localePath(locale, "/")} class="flex items-center gap-2.5">
      <img
        src="/logo.png"
        alt={t(locale, "metadata.logoAlt")}
        class="h-9 w-9 rounded-full"
        width="36"
        height="36"
      />
      <span class="hidden font-display text-lg font-semibold sm:inline">Diver's Notes</span>
    </a>
    <nav class="flex flex-1 items-center gap-6 text-[15px]">
      {nav.map((item) => (
        <a
          href={localePath(locale, item.href)}
          class:list={[
            "pb-0.5 transition-colors",
            isActive(item.href)
              ? "border-b-2 border-action font-medium text-ink"
              : "text-muted hover:text-ink",
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>
    <Search locale={locale} />
    <button
      id="theme-toggle"
      aria-label={t(locale, "theme.toggle")}
      class="rounded-full border border-line bg-surface px-3 py-1.5 font-mono text-xs text-muted transition-colors hover:text-ink"
    >
      <span class="dark:hidden">☾</span><span class="hidden dark:inline">☀</span>
    </button>
    <a
      href={alternatePath(locale, path)}
      class="rounded-full border border-line bg-surface px-3 py-1.5 font-mono text-xs text-muted transition-colors hover:text-ink"
    >
      {locale === "ru" ? "EN" : "RU"}
    </a>
  </div>
</header>

<script>
  document.getElementById("theme-toggle")?.addEventListener("click", () => {
    const dark = document.documentElement.classList.toggle("dark");
    localStorage.setItem("theme", dark ? "dark" : "light");
  });
</script>
