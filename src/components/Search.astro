---
import { t, type Locale } from "../lib/i18n";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
---

<button
  id="search-open"
  aria-label={t(locale, "search.openSearch")}
  class="rounded-full border border-line bg-surface px-3 py-1.5 font-mono text-xs text-muted transition-colors hover:text-ink"
>
  ⌕ <span class="hidden md:inline">⌘K</span>
</button>

<dialog
  id="search-dialog"
  class="m-auto w-full max-w-xl rounded-3xl bg-surface p-6 text-ink shadow-card backdrop:bg-[#0A1B24]/60"
>
  <div class="mb-3 flex items-center justify-between">
    <h2 class="font-display font-semibold">{t(locale, "search.searchSite")}</h2>
    <button id="search-close" aria-label={t(locale, "search.closeSearch")} class="p-1 text-muted hover:text-ink">✕</button>
  </div>
  <div id="pagefind-search" data-placeholder={t(locale, "search.placeholder")}></div>
</dialog>

<script>
  const dialog = document.getElementById("search-dialog") as HTMLDialogElement;
  let loaded = false;

  async function openSearch() {
    dialog.showModal();
    if (loaded) return;
    loaded = true;
    const el = document.getElementById("pagefind-search")!;
    try {
      // Pagefind assets exist only in the production build (postbuild step).
      // The path is computed so Vite doesn't try to resolve it at dev/build time.
      const base = "/pagefind";
      const css = document.createElement("link");
      css.rel = "stylesheet";
      css.href = `${base}/pagefind-ui.css`;
      document.head.append(css);
      const { PagefindUI } = await import(/* @vite-ignore */ `${base}/pagefind-ui.js`);
      new PagefindUI({
        element: el,
        showSubResults: true,
        translations: { placeholder: el.dataset.placeholder },
      });
    } catch {
      el.textContent = "Search index is available in the production build only.";
    }
  }

  document.getElementById("search-open")?.addEventListener("click", openSearch);
  document.getElementById("search-close")?.addEventListener("click", () => dialog.close());
  document.addEventListener("keydown", (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === "k") {
      e.preventDefault();
      dialog.open ? dialog.close() : openSearch();
    }
  });
</script>