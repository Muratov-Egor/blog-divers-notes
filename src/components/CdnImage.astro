---
import { resolveImage } from "../lib/images";

interface Props {
  src: string;
  alt: string;
  sizes?: string;
  class?: string;
  loading?: "lazy" | "eager";
}

const { src, alt, sizes = "(max-width: 768px) 100vw, 720px", class: cls, loading = "lazy" } = Astro.props;
const img = resolveImage(src);
---

<img
  src={img.src}
  srcset={img.srcset}
  sizes={img.srcset ? sizes : undefined}
  width={img.width}
  height={img.height}
  alt={alt}
  loading={loading}
  decoding="async"
  class={cls}
/>
