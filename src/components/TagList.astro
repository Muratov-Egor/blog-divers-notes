---
import { localePath, type Locale } from "../lib/i18n";
import { tagByName, tagLabel } from "../lib/content";

interface Props {
  tags: string[];
  locale: Locale;
  class?: string;
}
const { tags, locale, class: cls } = Astro.props;
const chip = "rounded-full bg-lagoon/10 px-3 py-1 text-xs text-lagoon";
---

{tags.length > 0 && (
  <ul class:list={["flex flex-wrap gap-2", cls]}>
    {tags.map((tag) => {
      const meta = tagByName(tag);
      const label = tagLabel(tag, locale);
      return (
        <li>
          {meta ? (
            <a href={localePath(locale, `/tags/${meta.slug}`)} class={`${chip} transition-colors hover:bg-lagoon/20`}>
              {label}
            </a>
          ) : (
            <span class={chip}>{label}</span>
          )}
        </li>
      );
    })}
  </ul>
)}
