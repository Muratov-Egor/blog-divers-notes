---
import CdnImage from "./CdnImage.astro";
import TagList from "./TagList.astro";
import { t, localePath, formatDate, type Locale } from "../lib/i18n";
import { readingTime, type BlogPost } from "../lib/content";

interface Props {
  post: BlogPost;
  locale: Locale;
  /** Full-width hero card (used for the newest post on the blog index). */
  featured?: boolean;
}
const { post, locale, featured = false } = Astro.props;
const minutes = readingTime(post.body);
const href = localePath(locale, `/blog/${post.data.slug}`);
---

<article
  class:list={[
    "group overflow-hidden rounded-3xl bg-surface shadow-card transition-transform duration-300 motion-safe:hover:-translate-y-1",
    featured ? "flex flex-col md:flex-row" : "flex flex-col",
  ]}
>
  {post.data.cover && (
    <a href={href} class:list={["block overflow-hidden", featured && "md:w-3/5 md:shrink-0"]}>
      <CdnImage
        src={post.data.cover}
        alt={post.data.title}
        sizes={featured ? "(max-width: 768px) 100vw, 760px" : "(max-width: 640px) 100vw, 400px"}
        class:list={[
          "w-full object-cover transition-transform duration-500 motion-safe:group-hover:scale-[1.03]",
          featured ? "aspect-[16/10] md:h-full md:aspect-auto" : "aspect-[16/10]",
        ]}
      />
    </a>
  )}
  <div class:list={["flex flex-1 flex-col gap-2.5 p-6", featured && "md:justify-center md:p-10"]}>
    <div class="font-mono text-xs text-muted">
      <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date, locale)}</time>
      {" · "}
      {t(locale, "blog.readingTime").replace("{minutes}", String(minutes))}
    </div>
    <a href={href}>
      <h2
        class:list={[
          "font-display leading-snug font-semibold group-hover:text-lagoon",
          featured ? "text-2xl md:text-3xl" : "text-xl",
        ]}
      >
        {post.data.title}
      </h2>
    </a>
    <p class:list={["flex-1 text-muted", featured ? "text-base md:flex-none" : "text-[15px]"]}>
      {post.data.description}
    </p>
    <TagList tags={post.data.tags.slice(0, featured ? 5 : 3)} locale={locale} class="mt-1" />
  </div>
</article>
