---
import CdnImage from "./CdnImage.astro";
import TagList from "./TagList.astro";
import { localePath, formatDate, type Locale } from "../lib/i18n";
import type { BlogPost } from "../lib/content";

interface Props {
  post: BlogPost;
  locale: Locale;
}
const { post, locale } = Astro.props;
---

<article class="flex flex-col gap-3 rounded-xl border border-slate-200 p-4 transition-shadow hover:shadow-md sm:flex-row dark:border-ocean-800">
  {post.data.cover && (
    <a href={localePath(locale, `/blog/${post.data.slug}`)} class="shrink-0">
      <CdnImage
        src={post.data.cover}
        alt={post.data.title}
        sizes="(max-width: 640px) 100vw, 240px"
        class="h-40 w-full rounded-lg object-cover sm:h-32 sm:w-48"
      />
    </a>
  )}
  <div class="min-w-0">
    <a href={localePath(locale, `/blog/${post.data.slug}`)}>
      <h2 class="text-lg font-semibold hover:text-ocean-600 dark:hover:text-ocean-300">
        {post.data.title}
      </h2>
    </a>
    <time class="text-sm text-slate-500 dark:text-slate-400" datetime={post.data.date.toISOString()}>
      {formatDate(post.data.date, locale)}
    </time>
    <p class="mt-1 text-sm text-slate-600 dark:text-slate-300">{post.data.description}</p>
    <TagList tags={post.data.tags} locale={locale} class="mt-2" />
  </div>
</article>
