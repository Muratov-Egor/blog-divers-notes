---
import CdnImage from "./CdnImage.astro";
import TagList from "./TagList.astro";
import { t, localePath, formatDate, type Locale } from "../lib/i18n";
import { readingTime, type BlogPost } from "../lib/content";

interface Props {
  post: BlogPost;
  locale: Locale;
}
const { post, locale } = Astro.props;
const minutes = readingTime(post.body);
const href = localePath(locale, `/blog/${post.data.slug}`);
---

<article
  class="group flex flex-col overflow-hidden rounded-3xl bg-surface shadow-card transition-transform duration-300 motion-safe:hover:-translate-y-1"
>
  {post.data.cover && (
    <a href={href} class="block overflow-hidden">
      <CdnImage
        src={post.data.cover}
        alt={post.data.title}
        sizes="(max-width: 640px) 100vw, 400px"
        class="aspect-[16/10] w-full object-cover transition-transform duration-500 motion-safe:group-hover:scale-[1.03]"
      />
    </a>
  )}
  <div class="flex flex-1 flex-col gap-2.5 p-6">
    <div class="font-mono text-xs text-muted">
      <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date, locale)}</time>
      {" · "}
      {t(locale, "blog.readingTime").replace("{minutes}", String(minutes))}
    </div>
    <a href={href}>
      <h2 class="font-display text-xl leading-snug font-semibold group-hover:text-lagoon">
        {post.data.title}
      </h2>
    </a>
    <p class="flex-1 text-[15px] text-muted">{post.data.description}</p>
    <TagList tags={post.data.tags.slice(0, 3)} locale={locale} class="mt-1" />
  </div>
</article>
