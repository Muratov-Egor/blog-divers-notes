# Public host that serves the image bucket (Cloudflare-proxied custom domain).
# Falls back to the raw Backblaze URL when unset.
PUBLIC_IMAGE_CDN=https://images.diversnotes.com

# S3-compatible credentials for scripts/optimize-images.mjs (R2 or Backblaze B2).
IMAGES_S3_ENDPOINT=
IMAGES_S3_REGION=auto
IMAGES_S3_BUCKET=diversnotes-images
IMAGES_S3_KEY_ID=
IMAGES_S3_SECRET=
